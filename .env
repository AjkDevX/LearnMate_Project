# ==========================================================
# LearnMate -- IBM watsonx.ai Environment Configuration
# ==========================================================

# IBM Cloud API Key (from IBM Cloud > Manage > Access > API Keys)
IBM_API_KEY=YOUR_IBM_API_KEY_HERE

# IBM Watsonx.ai Service URL (region-specific)
IBM_WATSONX_URL=https://au-syd.ml.cloud.ibm.com

# IBM Watsonx.ai Project ID (from Watsonx.ai > Projects > your project > Manage)
IBM_PROJECT_ID=YOUR_PROJECT_ID_HERE

# Flask secret key -- change to a long random string in production
FLASK_SECRET_KEY=learnmate-super-secret-key-change-in-production

# Flask environment: development | production
FLASK_ENV=development

# Model ID (Switched to Meta Llama for Sydney Region Support)
WATSONX_MODEL_ID=meta-llama/llama-3-3-70b-instruct
